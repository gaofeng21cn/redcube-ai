# RedCube AI 多API密钥配置示例
# 复制到项目根目录并重命名为 .env，然后填入真实的API密钥

# LLM网关（推荐）
LLM_BACKEND=litellm
MODEL_NAME=gemini-2.5-pro
# 可选：回退模型链（逗号分隔）
LITELLM_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# 可选：按模块路由模型（支持跨厂商 provider/model，如 openai/gpt-4o-mini）
MODEL_CONTENT_PLANNING=gemini-2.5-pro
MODEL_HTML_GENERATION=gemini-2.5-pro
MODEL_HTML_FIX=gemini-2.5-flash
MODEL_VISUAL_EVALUATION=gemini-2.5-flash

# V2 轻量版路由（可直接写 provider/model）
MODEL_NOTE_DRAFT=gemini/gemini-2.5-pro
MODEL_NOTE_REFINE=gemini/gemini-2.5-flash
NOTE_PARSING_STRATEGY=text_first

# 启用多API密钥管理
ENABLE_MULTI_API_KEYS=true

# 免费层级API密钥（用逗号分隔，建议配置3-5个）
# 每个密钥都有独立的配额限制
GEMINI_FREE_TIER_KEYS=AIzaSyABC...123,AIzaSyDEF...456,AIzaSyGHI...789

# 收费层级API密钥（可选，用逗号分隔）
# 当免费层级耗尽时自动使用
GEMINI_PAID_TIER_KEYS=AIzaSyPAID...001,AIzaSyPAID...002

# 备用单密钥（保持向后兼容）
GEMINI_API_KEY=AIzaSyBACKUP...999

# 其他厂商（按需配置，Web界面可直接修改）
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
QWEN_API_KEY=sk-...
MOONSHOT_API_KEY=sk-...
