{
  "name": "@redcube/runtime-family-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.js"
  },
  "redcube": {
    "defaultRuntimeFamilyModules": [
      {
        "overlayId": "ppt_deck",
