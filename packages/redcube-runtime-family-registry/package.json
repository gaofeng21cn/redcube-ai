      {
        "overlayId": "xiaohongshu",
        "deliverableKind": "xiaohongshu_note",
        "module": "@redcube/runtime-family-xiaohongshu",
        "exportName": "runXiaohongshuRoute"
      }
    ]
  },
  "dependencies": {
    "@redcube/runtime-family-ppt": "0.1.0",
    "@redcube/runtime-family-xiaohongshu": "0.1.0"
  }
}
