{
  "name": "redcube-ai-mono",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "redcube": "node apps/redcube-cli/src/cli.js",
    "mcp": "node apps/redcube-mcp/src/server.js",
    "test": "node scripts/run-test-group.mjs fast",
    "test:fast": "node scripts/run-test-group.mjs fast",
    "test:meta": "node scripts/run-test-group.mjs meta",
    "test:family": "node scripts/run-test-group.mjs family",
    "test:integration": "node scripts/run-test-group.mjs integration",
    "test:e2e": "node scripts/run-test-group.mjs e2e",
    "test:historical": "node scripts/run-test-group.mjs historical",
    "test:full": "node scripts/run-test-group.mjs full",
    "typecheck": "tsc --noEmit --project tsconfig.tests.json --pretty false",
    "audit:typescript-closeout": "node scripts/run-typescript-closeout-audit.mjs",
    "line-budget": "node scripts/line-budget.mjs"
  },
  "optionalDependencies": {
    "@mariozechner/pi-ai": "^0.54.2",
    "@mariozechner/pi-agent-core": "^0.54.2"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "@types/node": "^24.7.0"
  }
}
