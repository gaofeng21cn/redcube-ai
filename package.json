{
  "name": "redcube-ai-mono",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:smoke",
    "test:smoke": "node scripts/verify-lane.ts smoke",
    "test:fast": "node scripts/verify-lane.ts fast",
    "test:ci": "node scripts/verify-lane.ts ci",
    "test:historical": "node scripts/verify-lane.ts historical",
    "test:full": "node scripts/verify-lane.ts full",
    "test:full:with-historical": "node scripts/verify-lane.ts full:with-historical",
    "private-platform:readback": "node scripts/verify-lane.ts private-platform:readback",
    "test:private-platform:strict": "node scripts/verify-lane.ts private-platform:strict",
    "repo:hygiene": "scripts/repo-hygiene.sh",
    "repo:hygiene:fix": "scripts/repo-hygiene.sh --fix",
    "typecheck": "npm run --silent build && tsc --noEmit --project tsconfig.typecheck.json --pretty false",
    "typecheck:ci": "npm run --silent build:ci && tsc --noEmit --project tsconfig.typecheck.json --pretty false",
    "build": "tsc --noEmit --project tsconfig.json --pretty false",
    "build:ci": "tsc --noEmit --project tsconfig.json --pretty false",
    "audit:fallow:production": "npx --yes fallow@3.3.0 dead-code --root . --no-cache --production --summary --fail-on-issues",
    "line-budget": "node scripts/line-budget.ts",
    "line-budget:strict": "node scripts/line-budget.ts --strict"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "typescript": "^5.9.2"
  },
  "license": "Apache-2.0"
}
