{
  "name": "rca-local",
  "interface": {
    "displayName": "RedCube AI Local"
  },
  "plugins": [
    {
      "name": "rca",
      "source": {
        "source": "local",
        "path": "./plugins/rca"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "languageSurface": {
        "implementationTarget": "TypeScript orchestration + Python native helpers",
        "newCodeDefault": "TypeScript or Python under RedCube routes and gates",
        "javascriptPolicy": "Legacy allowlisted residue only; do not default new agent work to JavaScript"
      },
      "category": "Creative"
    }
  ]
}
