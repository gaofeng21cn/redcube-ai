{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/rca/stage-action.output.schema.json",
  "title": "RCA hosted stage action output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "stage_id",
    "status",
    "artifact_refs",
    "quality_debt_refs",
    "negative_result_refs",
    "failed_path_refs",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "rca_stage_action_result"
    },
    "schema_version": {
      "const": 1
    },
    "stage_id": {
      "enum": [
        "source_intake",
        "communication_strategy",
        "visual_direction",
        "artifact_creation",
        "review_and_revision",
        "package_and_handoff"
      ]
    },
    "status": {
      "enum": [
        "completed",
        "completed_with_quality_debt",
        "route_back",
        "typed_blocker",
        "human_gate",
        "failed",
        "no_output"
      ]
    },
    "stage_outcome_ref": {
      "$ref": "#/$defs/nullable_typed_ref"
    },
    "artifact_refs": {
      "$ref": "#/$defs/typed_refs"
    },
    "owner_receipt_ref": {
      "$ref": "#/$defs/nullable_typed_ref"
    },
    "typed_blocker_ref": {
      "$ref": "#/$defs/nullable_typed_ref"
    },
    "human_gate_ref": {
      "$ref": "#/$defs/nullable_typed_ref"
    },
    "route_back_ref": {
      "$ref": "#/$defs/nullable_typed_ref"
    },
    "quality_debt_refs": {
      "$ref": "#/$defs/typed_refs"
    },
    "negative_result_refs": {
      "$ref": "#/$defs/typed_refs"
    },
    "failed_path_refs": {
      "$ref": "#/$defs/typed_refs"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain_truth_owner",
        "quality_verdict_owner",
        "artifact_authority_owner",
        "opl_can_write_domain_truth",
        "opl_can_mutate_domain_artifact_body",
        "opl_can_authorize_quality_or_export",
        "provider_completion_is_domain_completion"
      ],
      "properties": {
        "domain_truth_owner": {
          "const": "redcube_ai"
        },
        "quality_verdict_owner": {
          "const": "redcube_ai"
        },
        "artifact_authority_owner": {
          "const": "redcube_ai"
        },
        "opl_can_write_domain_truth": {
          "const": false
        },
        "opl_can_mutate_domain_artifact_body": {
          "const": false
        },
        "opl_can_authorize_quality_or_export": {
          "const": false
        },
        "provider_completion_is_domain_completion": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "typed_ref": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "ref"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        }
      ]
    },
    "nullable_typed_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/typed_ref"
        },
        {
          "type": "null"
        }
      ]
    },
    "typed_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/typed_ref"
      },
      "uniqueItems": true
    }
  }
}
