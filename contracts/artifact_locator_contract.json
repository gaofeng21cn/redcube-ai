{
  "surface_kind": "artifact_locator_contract",
  "contract_id": "rca.workspace_runtime_artifact_locator.v1",
  "domain_id": "redcube_ai",
  "owner": "redcube_ai",
  "locator_model": "opl_stage_folder_contract_refs_only",
  "primary_artifact_truth": {
    "surface_kind": "opl_stage_folder_contract_consumer",
    "contract_id": "rca.opl_stage_folder_artifact_runtime.v1",
    "physical_root_template": "$OPL_STATE_DIR/runtime-state/domains/redcube_ai/deliverables/<program_id>/<topic_id>/<deliverable_id>/stages/<nn-stage>/attempts/<attempt_id>/",
    "required_attempt_members": [
      "attempt.json",
      "manifest.json",
      "inputs/",
      "outputs/",
      "evidence/",
      "receipts/"
    ],
    "current_pointer_refs": [
      "current.json",
      "latest.json",
      "stages/<nn-stage>/current.json",
      "stages/<nn-stage>/latest"
    ],
    "completion_rule": "required output roles plus a valid role manifest advance with a progress receipt; owner receipt is additionally required for quality/export/ready claims",
    "blocked_rule": "zero readable artifact materializes a no-output diagnostic and quality debt; only execution, authority, safety, human-decision, irreversible-action, or identity/currentness boundaries use typed blocker refs",
    "orphan_rule": "outputs without a valid role manifest remain non-authoritative quality-debt inputs; they never authorize quality, export, or ready claims but do not block the next stage",
    "program_identity_rule": "RCA derives program_id from workspace root so same topic_id/deliverable_id in different workspaces cannot collide in shared OPL runtime-state"
  },
  "workspace_runtime_artifact_root": {
    "ref_kind": "runtime_path",
    "root_id": "workspace_runtime_artifact_root",
    "workspace_root": "<workspace_root>",
    "runtime_state_root": "<runtime_state_root>",
    "session_continuity_root": "<session_continuity_root>",
    "path_template": "<workspace-root>/.redcube/runtime/artifacts/<topic_id>/<deliverable_id>/<run_id>",
    "status": "legacy_auxiliary_or_native_helper_output_root_not_completion_truth"
  },
  "artifact_ref_schema": {
    "required_fields": [
      "artifact_kind",
      "ref_kind",
      "artifact_ref",
      "topic_id",
      "deliverable_id",
      "run_id",
      "sha256"
    ],
    "allowed_artifact_kinds": [
      "png_page",
      "pptx_export",
      "pdf_export",
      "prompt_manifest",
      "stage_folder_manifest",
      "style_manifest",
      "review_capture",
      "owner_receipt",
      "typed_blocker",
      "export_bundle"
    ],
    "allowed_ref_kinds": [
      "opl_stage_folder_output",
      "opl_stage_folder_manifest",
      "opl_stage_folder_receipt",
      "opl_stage_folder_blocker_evidence",
      "workspace_runtime_artifact",
      "product_entry_session_ref",
      "stage_run_artifact_ref"
    ]
  },
  "repo_source_boundary": {
    "repo_tracks_descriptors_and_contracts": true,
    "repo_tracks_visual_or_export_artifact_blobs": false,
    "forbidden_repo_artifact_roots": [
      "artifacts/",
      "runtime-state/",
      ".runtime-program/",
      ".redcube/runtime/artifacts/"
    ]
  },
  "opl_consumption_policy": {
    "allowed": [
      "read_artifact_descriptor",
      "read_artifact_ref",
      "read_hash_and_locator",
      "rebuild_stage_artifact_index_from_physical_folders",
      "read_orphan_broken_stale_artifact_projection",
      "pickup_via_redcube_session_surface"
    ],
    "forbidden": [
      "store_png_pptx_pdf_blob",
      "issue_rca_owner_receipt",
      "declare_visual_export_verdict",
      "rewrite_canonical_artifact",
      "mutate_review_state"
    ]
  },
  "authority_boundary": {
    "domain_truth_owner": "redcube_ai",
    "artifact_authority_owner": "redcube_ai",
    "owner_receipt_owner": "redcube_ai",
    "visual_review_export_verdict_owner": "redcube_ai",
    "opl_role": "stage_folder_locator_index_rebuild_status_explain_gallery_handoff_shell",
    "opl_can_issue_owner_receipt": false,
    "opl_can_write_visual_truth": false,
    "opl_can_write_review_export_verdict": false,
    "opl_can_write_domain_artifact_body": false,
    "derived_read_model_is_first_truth": false
  }
}
