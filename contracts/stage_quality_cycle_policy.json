{
  "surface_kind": "opl_domain_stage_quality_cycle_profile",
  "version": "domain-stage-quality-cycle-profile.v1",
  "profile_id": "rca.official_high_value_visual_deliverable.v1",
  "target_domain_id": "redcube_ai",
  "shared_contract_ref": "opl-framework:contracts/opl-framework/stage-quality-cycle-contract.json",
  "route_selection_contract_ref": "opl-framework:contracts/opl-framework/stage-quality-cycle-contract.json#/cross_stage_route_selection",
  "cross_stage_route_selection": {
    "primary_only_decisive_attempt_role": "producer",
    "formal_review_decisive_attempt_roles": ["reviewer", "re_reviewer"],
    "repairer_can_be_decisive_attempt": false,
    "producer_can_be_decisive_attempt_in_formal_review": false,
    "repair_required_review_or_re_review_may_select_cross_stage_route_back_before_budget_exhaustion": true,
    "repair_required_cross_stage_route_back_requires_target_different_from_current_stage": true,
    "repair_required_review_or_re_review_may_select_other_terminal_route_before_budget_exhaustion": false,
    "repair_required_review_or_re_review_may_select_terminal_route_after_budget_exhaustion": true,
    "same_stage_repair_required_with_budget_remaining_continues_quality_loop": true,
    "cross_stage_route_back_requires_narrowest_canonical_owner_stage": true
  },
  "attempt_roles": [
    "producer",
    "reviewer",
    "repairer",
    "re_reviewer"
  ],
  "handoff_authority_sequence": {
    "steps": [
      "terminal_reviewer_or_re_reviewer_outcome",
      "opl_controller_formal_review_receipt",
      "rca_domain_owner_receipt",
      "ready_projection"
    ],
    "attempt_can_materialize_review_receipt": false,
    "attempt_can_materialize_owner_receipt": false,
    "route_helper_can_set_ready_claim": false
  },
  "context_isolation": {
    "required_for_formal_review": true,
    "new_stage_attempt_required": true,
    "new_executor_session_required": true,
    "no_context_inheritance": true,
    "producer_session_must_differ_from_reviewer_session": true,
    "repairer_session_must_differ_from_reviewer_session": true,
    "re_reviewer_session_must_differ_from_repairer_session": true,
    "same_thread_refinement_name": "in_thread_refinement",
    "same_thread_refinement_is_review": false,
    "same_thread_refinement_can_issue_review_receipt": false,
    "allowed_reviewer_context": [
      "stage_goal_ref",
      "exact_artifact_refs_and_hashes",
      "source_refs_and_fingerprint",
      "quality_rubric_refs",
      "required_artifact_lineage",
      "prior_finding_refs_for_re_review"
    ],
    "forbidden_reviewer_context": [
      "producer_conversation_history",
      "producer_thread_resume",
      "producer_reasoning_trace",
      "undeclared_transient_context"
    ]
  },
  "attempt_route_execution_policy": {
    "route_is_stage_internal_operation": true,
    "attempt_role_round_and_context_validation_owner": "opl_stage_run_controller",
    "attempt_role_is_never_inferred_or_validated_from_route_name": true,
    "all_quality_attempts_require_fresh_context": true,
    "rca_route_handler_consumes_attempt_metadata_passively": true,
    "rca_route_handler_can_reject_role_round_or_review_context_shape": false,
    "missing_attempt_metadata_result": "completed_with_quality_debt",
    "explicit_owner_or_identity_mismatch_result": "hard_stop",
    "missing_attempt_metadata_blocks_stage_transition": false,
    "professional_route_sequence_remains_domain_owned": true,
    "stage_transition_authority_is_not_granted_by_route_execution": true
  },
  "quality_budget": {
    "max_repair_rounds": 3,
    "initial_production_counts_as_repair_round": false,
    "round_definition": "repairer_attempt_plus_fresh_re_reviewer_attempt",
    "provider_retry_consumes_quality_budget": false,
    "protocol_closeout_resume_consumes_quality_budget": false,
    "on_exhaustion_with_consumable_artifact": "completed_with_quality_debt",
    "on_exhaustion_without_consumable_artifact": "typed_blocker",
    "repair_required_outcome_is_preserved_at_exhaustion": true,
    "repair_required_at_exhaustion_with_consumable_artifact_is_terminal_decisive": true,
    "zero_repair_round_budget_makes_initial_review_terminal": true
  },
  "budget_separation": {
    "stage_quality_revision_budget_owner": "opl_stage_run_controller",
    "per_route_repeat_budget_owner": "redcube_ai_route_handler",
    "per_route_repeat_budget_consumes_stage_quality_budget": false,
    "provider_retry_consumes_stage_quality_budget": false,
    "only_repairer_plus_fresh_re_reviewer_closes_one_stage_quality_round": true
  },
  "finding_and_repair_contract": {
    "review_findings_required": true,
    "attempt_outcome_field": "route_impact.stage_quality_cycle.outcome",
    "review_attempt_outcomes": [
      "pass",
      "repair_required",
      "quality_debt",
      "blocked",
      "human_gate"
    ],
    "attempt_outcome_authorized_roles": [
      "reviewer",
      "re_reviewer"
    ],
    "producer_may_emit_attempt_outcome": false,
    "repairer_may_emit_attempt_outcome": false,
    "review_receipt_materialization": {
      "owner": "opl_stage_run_controller",
      "receipt_field": "verdict",
      "outcome_to_verdict": {
        "pass": "pass",
        "repair_required": "repair_required",
        "quality_debt": "quality_debt",
        "blocked": "hard_stop",
        "human_gate": "hard_stop"
      }
    },
    "quality_debt_stage_run_projection": "completed_with_quality_debt",
    "blocked_or_human_gate_can_emit_stage_route_decision": false,
    "route_output_policy": {
      "pass": "terminal_stage_route_decision",
      "quality_debt": "terminal_stage_route_decision",
      "same_stage_repair_required": "continue_quality_loop_with_stage_route_recommendation",
      "cross_stage_route_back_before_budget_exhaustion": "terminal_stage_route_decision",
      "repair_required_at_budget_exhaustion_with_consumable_artifact": "terminal_stage_route_decision_and_completed_with_quality_debt",
      "repair_required_at_budget_exhaustion_without_consumable_artifact": "no_stage_route_decision_and_typed_blocker",
      "blocked_or_human_gate": "no_stage_route_decision"
    },
    "reviewer_required_outputs": [
      "finding_refs",
      "outcome",
      "evidence_refs",
      "repair_expectation_refs"
    ],
    "finding_fields": [
      "finding_id",
      "severity",
      "required",
      "evidence_refs",
      "repair_expectation"
    ],
    "repairer_required_outputs": [
      "artifact_identity",
      "repair_map"
    ],
    "repair_map_required_for_each_required_finding": true,
    "repair_map_fields": [
      "finding_id",
      "repair_status",
      "changed_artifact_refs",
      "repair_evidence_refs"
    ],
    "re_review_closure_required": true,
    "re_reviewer_required_outputs": [
      "finding_closures",
      "outcome",
      "evidence_refs",
      "remaining_quality_debt_refs"
    ],
    "re_review_closure_fields": [
      "finding_id",
      "status",
      "evidence_refs"
    ],
    "closure_status_values": [
      "closed",
      "partially_closed",
      "still_open"
    ],
    "next_repair_round_triggers": [
      "required_finding_not_closed",
      "repair_regression",
      "critical_new_finding"
    ],
    "next_round_required_finding_sources": [
      "required_finding_not_closed",
      "repair_regression",
      "critical_new_finding"
    ],
    "reopened_finding_id_must_be_unique_across_cycle": true,
    "repair_regression_or_critical_new_finding_becomes_required": true,
    "ordinary_new_suggestion_policy": "optional_observation_without_reopening_loop",
    "pass_with_optional_observations_allowed": true,
    "optional_observation_alone_forces_quality_debt": false
  },
  "professional_sequence": {
    "ppt_visual_quality_loop": [
      "candidate",
      "render_and_mechanical_evidence",
      "visual_director_route_qa_evidence",
      "screenshot_route_qa_evidence",
      "targeted_repair",
      "rerender",
      "fresh_re_review"
    ],
    "sequence_is_domain_required": true,
    "tool_choice_within_step_is_executor_autonomous": true
  },
  "stage_policies": {
