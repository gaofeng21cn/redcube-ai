{
  "surface_kind": "opl_agent_package_manifest.v1",
  "agent_id": "rca",
  "package_id": "rca",
  "display_name": "RedCube AI",
  "publisher": "one-person-lab",
  "version": "0.2.2",
  "source": "first_party_repo_local",
  "carrier_source_role": "codex_plugin_default_carrier_not_package_truth",
  "source_repo": "https://github.com/gaofeng21cn/redcube-ai.git",
  "schema_ref": "one-person-lab/contracts/opl-framework/agent-package-manifest.schema.json",
  "source_contract": {
    "central_manifest_ref": "contracts/opl-framework/packages/rca.json",
    "central_package_id": "rca",
    "repo_canonical_agent_id": "rca",
    "repo_slug": "redcube-ai",
    "repo_domain_manifest_ref": "contracts/opl_domain_manifest_registration.json",
    "domain_descriptor_ref": "contracts/domain_descriptor.json",
    "pack_compiler_input_ref": "contracts/pack_compiler_input.json"
  },
  "machine_boundary": "This repo-local sidecar declares RCA package distribution and Codex carrier projection. OPL Connect owns package core, lock, lifecycle receipt, exposure, update, and rollback readback. RCA keeps visual truth, route truth, review/export verdict, artifact authority, visual memory body, and owner receipt authority; this manifest does not create a repo-owned generic runtime or package manager.",
  "package_core": {
    "core_kind": "opl_agent_package_core",
    "identity_fields": [
      "package_id",
      "agent_id",
      "version"
    ],
    "content_identity_fields": [
      "manifest_sha256",
      "payload_digest_ref",
      "required_skill_pack_lock_refs",
      "package_lock_ref"
    ],
    "dependency_source": "manifest_declared_capability_dependencies",
    "lock_owner": "opl_connect_agent_package_registry",
    "lifecycle_receipt_owner": "opl_connect_agent_package_registry",
    "exposure_owner": "opl_connect_agent_package_registry"
  },
  "codex_surface": {
    "plugin_id": "redcube-ai",
    "codex_visible_entry": "redcube-ai",
    "standalone_distribution": "repo_carrier_source",
    "required_skill_ids": [
      "redcube-ai"
    ],
    "bundled_capability_package_ids": [],
    "user_install_action_count": 1,
    "carrier_source_path": "plugins/redcube-ai",
    "canonical_primary_skill_source_ref": "agent/primary_skill/SKILL.md",
    "plugin_carrier_skill_ref": "plugins/redcube-ai/skills/redcube-ai/SKILL.md"
  },
  "lifecycle": {
    "owner": "opl_packages",
    "module_id": "rca",
    "commands": {
      "install": "opl packages install rca",
      "update": "opl packages update rca",
      "uninstall": "opl packages uninstall rca"
    },
    "repo_local_installer_allowed": false,
    "repo_local_marketplace_mutation_allowed": false,
    "repo_local_user_symlink_mutation_allowed": false
  },
  "skill_packs": [
    {
      "id": "redcube-ai",
      "source": "repo_local_codex_plugin_carrier",
      "version": "0.2.2",
      "install_mode": "bundled_required",
      "source_ref": "agent/primary_skill/SKILL.md",
      "carrier_mirror_ref": "plugins/redcube-ai/skills/redcube-ai/SKILL.md",
      "carrier_projection_contract_ref": "contracts/capability_map.json#/carrier_projection_contract"
    }
  ],
  "entrypoints": [
    {
      "entrypoint_id": "codex_primary_skill",
      "entrypoint_kind": "codex_skill",
      "source_ref": "agent/primary_skill/SKILL.md",
      "carrier_ref": "plugins/redcube-ai/skills/redcube-ai/SKILL.md",
      "authority": "carrier_only_not_domain_truth"
    },
    {
      "entrypoint_id": "hosted_stage_actions",
      "entrypoint_kind": "opl_hosted_action_catalog",
      "source_ref": "contracts/action_catalog.json",
      "authority": "opl_hosted_runtime_rca_domain_semantics"
    }
  ],
  "health_check": {
    "health_check_id": "rca_repo_local_opl_agent_package_manifest",
    "checks": [
      {
        "check_id": "json_parse",
        "command": "node -e \"JSON.parse(require('node:fs').readFileSync('contracts/opl_agent_package_manifest.json','utf8'))\""
      },
      {
        "check_id": "opl_manifest_validation",
        "command": "one-person-lab/bin/opl packages validate-manifest --manifest-url <repo>/contracts/opl_agent_package_manifest.json --json"
      }
    ],
    "does_not_authorize_runtime_ready": true,
    "does_not_authorize_live_download": true
  },
  "permissions": [
    {
      "permission_id": "repo_contract_read",
      "scope": "contracts_and_codex_carrier_refs",
      "access": "read"
    },
    {
      "permission_id": "artifact_mutation",
      "scope": "owner_authorized_visual_workspace_only",
      "access": "requires_rca_artifact_authority_receipt"
    }
  ],
  "update_channel": "manifest_url",
  "rollback_ref": "rollback-ref:rca/unavailable",
  "codex_visible_entry": "redcube-ai",
  "required_skill_ids": [
    "redcube-ai"
  ],
  "optional_skill_refs": [],
  "carrier_adapters": [
    {
      "adapter_kind": "codex_plugin_carrier",
      "carrier": "codex_plugin",
      "source_surface": "codex_surface",
      "projection_role": "package_carrier_adapter",
      "owns_package_core": false,
      "owns_domain_truth": false
    }
  ],
  "opl_managed_surface": {
    "package_shape": "thin_agent_package",
    "dependency_resolution": "managed_dependency_graph",
    "dependency_update_policy": "independent_package_target",
    "developer_mode_dependency_policy": "source_checkout_when_authorized_else_pull_request"
  },
  "managed_shell": {
    "clean_runner_profile": {
      "profile_role": "domain_compatibility_clean_runner",
      "legacy_env_roots": [
        {
          "env_name": "RCA_CLEAN_RUNNER_TMP_ROOT",
          "fallback_subdir": "rca"
        }
      ],
      "read_only_command_patterns": []
    }
  },
  "authority_boundary": {
    "repo_manifest_role": "repo_local_package_sidecar",
    "package_core_owner": "opl_connect_agent_package_registry",
    "package_lifecycle_receipt_owner": "opl_connect_agent_package_registry",
    "package_exposure_owner": "opl_connect_agent_package_registry",
    "domain_truth_owner": "redcube_ai",
    "rca_owns_visual_truth": true,
    "rca_owns_route_truth": true,
    "rca_owns_review_export_verdict": true,
    "rca_owns_artifact_authority": true,
    "rca_owns_visual_memory_body": true,
    "rca_owns_owner_receipt": true,
    "repo_can_own_generic_runtime": false,
    "repo_can_own_generic_package_manager": false,
    "manifest_can_write_domain_truth": false,
    "manifest_can_write_visual_truth": false,
    "manifest_can_write_visual_memory_body": false,
    "manifest_can_mutate_artifact_body": false,
    "manifest_can_authorize_review_export_verdict": false,
    "manifest_can_sign_owner_receipt": false,
    "manifest_can_create_typed_blocker": false,
    "manifest_can_write_runtime_queue": false,
    "manifest_can_claim_runtime_readiness": false,
    "manifest_can_claim_release_readiness": false,
    "manifest_can_claim_live_package_download": false
  },
  "capability_dependencies": []
}
