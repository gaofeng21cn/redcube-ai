{
  "contract_id": "ppt-native-authoring-proof-lane",
  "date_anchor": "2026-04-25",
  "status": "runtime_proof_landed",
  "owner": "redcube_ai",
  "deliverable_family": "ppt_deck",
  "scope": {
    "goal": "Evaluate direct native PPTX authoring and repair as an opt-in replacement for the HTML authoring stages.",
    "default_mainline_changed": false,
    "default_visual_route": "render_html",
    "replaces_routes": [
      "render_html",
      "fix_html"
    ],
    "preserved_upstream_routes": [
      "storyline",
      "detailed_outline",
      "slide_blueprint",
      "visual_direction"
    ],
    "preserved_gate_routes": [
      "visual_director_review",
      "screenshot_review",
      "export_pptx"
    ],
    "out_of_scope": [
      "new public skill",
      "new product-entry semantics",
      "bypassing RedCube review/export gates",
      "replacing source truth, storyline, blueprint, or visual direction"
    ]
  },
  "candidate_route_model": {
    "lane_id": "ppt_deck_native_ppt_authoring_v0",
    "status": "opt_in_proof_lane",
    "default_enabled": false,
    "runnable_routes": [
      "author_pptx_native",
      "repair_pptx_native"
    ],
    "author_route": "author_pptx_native",
    "repair_route": "repair_pptx_native",
    "author_route_replaces": "render_html",
    "repair_route_replaces": "fix_html",
    "authoring_artifact": "native_pptx_file",
    "editable_artifact_required": true,
    "ai_first_editing_contract": {
      "contract_id": "ppt_native_ai_first_editing_contract_v1",
      "creative_owner": "llm_agent",
      "editable_shape_plan_required": true,
      "editable_shape_manifest_required": true,
      "python_helper_role": "execute_validate_export_only",
      "template_substitution_allowed": false,
      "preserved_gates": [
        "visual_director_review",
        "screenshot_review",
        "export_pptx"
      ]
    },
    "unit_repair_scope": {
      "repair_route": "repair_pptx_native",
      "scope": "page",
      "target_source": "screenshot_review.blocked_slide_ids",
      "passed_slides_reused": true,
      "preserved_slide_policy": "do_not_reauthor_passed_slides"
    },
    "review_input_surface": "rendered_pptx_screenshots",
    "native_ppt_quality_surface": {
      "quality_model": "shape_manifest_layout_metrics_v1",
      "source_surface_kind": "native_pptx",
      "required_per_slide_metrics": [
        "bounds",
        "text_char_count",
        "primary_points",
        "occupied_ratio",
        "edge_clearance",
        "overlap_pairs",
        "preview_screenshot_sha256",
        "preview_screenshot_dimensions"
      ],
      "fail_closed_when_missing": true,
      "review_behavior": "screenshot_review consumes native shape manifest metrics and blocks on missing or failing quality checks"
    },
    "runtime_executor_proof": {
      "author_executor": "packages/redcube-runtime-family-ppt/src/ppt-deck-runtime-family-parts/native-ppt.ts",
      "native_writer": "packages/redcube-runtime/scripts/ppt_deck_native.py",
      "engine_contract": "contracts/runtime-program/ppt-native-python-engine-contract.json",
      "route_surface": "runDeliverableRoute",
      "stage_sequence_model": "alternate_stages",
      "default_stage_sequence_changed": false,
      "export_behavior": "export_pptx copies the editable native source PPTX when the latest reviewed visual artifact is native PPTX"
    },
    "required_export_fields": [
      "export_bundle.source_pptx",
      "export_bundle.native_ppt_shape_manifest",
      "export_bundle.native_ppt_repair_log"
    ]
  },
  "promotion_gates": [
    "same topic/profile can run through HTML mainline and native-PPT proof lane without identity drift",
    "native PPTX produces editable slides rather than screenshot-only wrappers",
    "screenshot_review judges rendered PPTX screenshots as the final visible artifact",
    "repair route consumes review feedback and updates only the blocked PPTX pages when possible",
    "getReviewState and getPublicationProjection remain authoritative",
    "runManagedDeliverable and product-entry route gates remain fail-closed"
  ],
  "rollback_policy": {
    "default_mainline_impact": "none",
    "disable_action": "do not select the native PPT proof lane",
    "html_mainline_required_to_remain_green": true
  }
}
