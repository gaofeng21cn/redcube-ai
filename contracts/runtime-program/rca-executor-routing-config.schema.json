{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redcube.local/contracts/runtime-program/rca-executor-routing-config.schema.json",
  "title": "RedCube RCA Executor Routing Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version"],
  "$defs": {
    "opl_executor_adapter_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "owner",
        "hosted_adapter_reference",
        "selected_executor_backend",
        "backend_lifecycle",
        "rca_default_backend",
        "adapter_deletion_gate_owner",
        "adapter_deletion_gate",
        "domain_truth_owner",
        "review_export_gate_owner",
        "activation",
        "auditability",
        "failure_mode",
        "effect_equivalence_guaranteed"
      ],
      "properties": {
        "source": {
          "const": "opl_executor_adapter_receipt"
        },
        "owner": {
          "const": "opl_runtime_manager"
        },
        "hosted_adapter_reference": {
          "const": "opl_hosted:hermes_agent_loop"
        },
        "selected_executor_backend": {
          "const": "hermes_agent"
        },
        "backend_lifecycle": {
          "const": "historical_opt_in_deferred_external_adapter"
        },
        "rca_default_backend": {
          "const": false
        },
        "adapter_deletion_gate_owner": {
          "const": "opl_agent_executor_adapter"
        },
        "adapter_deletion_gate": {
          "type": "array",
          "items": {
            "enum": [
              "opl_agent_executor_adapter_default_caller_parity",
              "attempt_ledger_runtime_record_parity",
              "rca_route_policy_and_receipt_refs_preserved",
              "focused_proof_tests_migrated_to_opl_owned_surface",
              "no_active_rca_caller_scan",
              "rca_owner_receipt_or_typed_blocker"
            ]
          },
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true
        },
        "domain_truth_owner": {
          "const": "redcube_ai_visual_deliverable_runtime"
        },
        "review_export_gate_owner": {
          "const": "redcube_ai"
        },
        "activation": {
          "const": "explicit_opt_in_only"
        },
        "auditability": {
          "const": "receipt_backed"
        },
        "failure_mode": {
          "const": "fail_closed"
        },
        "effect_equivalence_guaranteed": {
          "const": false
        }
      }
    },
    "opl_hosted_executor_requirement": {
      "type": "object",
      "description": "Non-default external adapter policy ref only; RCA-owned Hermes implementation is retired and must fail closed until OPL owns the executor adapter receipt.",
      "additionalProperties": false,
      "required": ["source", "required_receipt_source", "hosted_adapter_reference"],
      "properties": {
        "source": {
          "const": "opl_hosted_executor_requirement"
        },
        "required_receipt_source": {
          "const": "opl_executor_adapter_receipt"
        },
        "hosted_adapter_reference": {
          "const": "opl_hosted:hermes_agent_loop"
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": 1
    },
    "default_executor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executor_backend": {
          "enum": ["codex_cli", "hermes_agent"]
        },
        "execution_shape": {
          "enum": ["structured_call", "agent_loop"]
        },
        "hermes_profile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "structured_call_routing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "default_on_missing": {
          "const": "inherit_effective_default_executor"
        },
        "routes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["executor_backend", "execution_shape"],
            "properties": {
              "executor_backend": {
                "enum": ["codex_cli", "hermes_agent"]
              },
              "execution_shape": {
                "const": "structured_call"
              },
              "lane": {
                "enum": ["production", "experimental_proof"],
                "default": "production"
              },
              "hermes_profile": {
                "type": "string",
                "minLength": 1
              },
              "opl_executor_adapter_receipt": {
                "$ref": "#/$defs/opl_executor_adapter_receipt"
              },
              "opl_hosted_executor_requirement": {
                "$ref": "#/$defs/opl_hosted_executor_requirement"
              },
              "fallback": {
                "enum": ["inherit_effective_default_executor", "fail_closed"]
              },
              "failure_policy": {
                "enum": ["fallback_with_proof", "fail_closed"]
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "executor_backend": {
                      "const": "hermes_agent"
                    }
                  },
                  "required": ["executor_backend"]
                },
                "then": {
                  "anyOf": [
                    {
                      "required": ["opl_executor_adapter_receipt"]
                    },
                    {
                      "required": ["opl_hosted_executor_requirement"]
                    }
                  ]
                }
              },
              {
                "if": {
                  "properties": {
                    "failure_policy": {
                      "const": "fallback_with_proof"
                    }
                  },
                  "required": ["failure_policy"]
                },
                "then": {
                  "required": ["lane", "fallback"],
                  "properties": {
                    "lane": {
                      "const": "experimental_proof"
                    },
                    "fallback": {
                      "const": "inherit_effective_default_executor"
                    }
                  }
                }
              }
            ]
          }
        }
      }
    }
  }
}
