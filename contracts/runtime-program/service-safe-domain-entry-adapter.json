{
  "entry_contract_id": "redcube_service_safe_domain_entry",
  "date_anchor": "2026-04-12",
  "status": "closeout_completed",
  "owner_surface": "@redcube/gateway invokeDomainEntry",
  "entry_goal": {
    "label": "service-safe RedCube domain entry for OPL Runtime Manager handoff",
    "summary": "Freeze one machine-readable RedCube domain adapter surface. Direct RedCube product-entry uses Codex CLI by default; the OPL-hosted path remains a thin product-managed adapter/projection layer over the configured family runtime provider, with domain truth on RedCube."
  },
  "opl_handoff_envelope": {
    "minimum_fields": [
      "target_domain_id",
      "task_intent",
      "entry_mode",
      "workspace_locator",
      "runtime_session_contract",
      "return_surface_contract"
    ],
    "target_domain_id": "redcube_ai"
  },
  "validation": {
    "mode": "fail_closed",
    "fail_closed_on_missing_fields": [
      "entry_mode",
      "runtime_session_contract.runtime_owner",
      "return_surface_contract.surface_kind"
    ],
    "task_intent_surface_kind_map": {
      "run_managed_deliverable": "managed_run",
      "run_deliverable_route": "route_run"
    }
  },
  "runtime_session_contract": {
    "default_runtime_owner": "codex_cli",
    "hosted_runtime_owner_when_federated": "configured_family_runtime_provider",
    "opl_runtime_manager_role": "product-managed adapter/projection layer over the configured family runtime provider",
    "adapter_surface": "@redcube/codex-cli-client",
    "session_mode": "ephemeral_run"
  },
  "redcube_domain_payload": {
    "required_fields": [
      "deliverable_family",
      "topic_id",
      "deliverable_id"
    ],
    "optional_fields": [
      "route",
      "adapter",
      "user_intent",
      "stop_after_stage",
      "mode",
      "baseline_deliverable_id"
    ]
  },
  "supported_task_intents": [
    "run_managed_deliverable",
    "run_deliverable_route"
  ],
  "return_surface_contract": {
    "supported_surface_kinds": [
      "managed_run",
      "route_run"
    ],
    "durable_truth_surfaces": [
      "runtimeWatch",
      "getReviewState",
      "getPublicationProjection",
      "auditDeliverable"
    ]
  },
  "excluded_scope": [
    "chat UI or natural-language shell",
    "new family onboarding",
    "controller expansion",
    "repackaging historical runtime naming as current proof",
    "claiming OPL Runtime Manager owns RedCube visual-domain truth or concrete executor"
  ]
}
