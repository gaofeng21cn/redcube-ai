      "bridge_connector",
      "decision_rail",
      "proof_rail",
      "evidence_axis"
    ],
    "sample_status_proof_board": {
      "vertical_drop_count": 3,
      "horizontal_bus_allowed": false,
      "max_vertical_drop_width_in": 0.04,
      "min_vertical_drop_height_in": 0.66,
      "directional_arrow_required": true
    }
  },
  "layout_rhythm": {
    "deck_layout_rhythm_plan_required": true,
    "no_three_consecutive_same_archetype": true,
    "no_three_consecutive_same_primary_grid": true,
    "repeated_concrete_composition_limit": 2,
    "min_distinct_composition_share": 0.75,
    "composition_signature_must_describe_geometry": true,
    "repair_must_change_repeated_concrete_geometry": true
  },
  "non_text_visual_requirements": {
