    "repair_pptx_native"
  ],
  "claims_visual_ready": false,
  "claims_exportable": false,
  "claims_handoffable": false,
  "claims_production_ready": false,
  "design_pack_boundary": {
    "creative_owner": "llm_agent",
    "python_helper_role": "execute_selected_archetype_zones_validate_materialize_only",
    "helper_template_layout_allowed": false,
    "helper_can_select_layout_archetype": false,
    "helper_can_replace_design_profile": false,
    "new_runtime_dependency_allowed": false,
    "third_party_code_copied": false,
    "third_party_template_asset_copied": false,
    "discipline_adoption_mode": "clean_room_design_discipline_only"
  },
  "layout_archetype_taxonomy": {
    "required": true,
    "selection_owner": "llm_agent",
    "selected_archetype_field": "editable_shape_plan.slides[].template_layout_binding.selected_archetype",
    "helper_selection_allowed": false,
    "archetype_catalog": [
      {
        "archetype_id": "professional_system_map",
        "use_when": "workflow, route, system, gate, or evidence flow needs first-glance structure",
        "layout_description": "A title and claim sit above an editable system map with route lanes, gate stack, evidence band, and connector lanes kept outside readable text.",
        "required_zones": [
          "title_zone",
          "claim_zone",
          "system_map_zone",
          "gate_zone",
          "evidence_zone"
        ],
        "content_schema": {
          "required_shape_roles": [
            "title",
            "core_sentence",
            "system_map_panel",
            "route_label",
            "gate_card",
            "evidence_item"
          ],
          "required_shape_role_groups": [
            "title_text",
            "core_claim_text",
            "structural_visual",
            "gate_or_route_label",
            "evidence_or_metric_text"
          ],
          "capacity_budget_ref": "#/capacity_budgets/archetype_budgets/professional_system_map"
        },
        "font_floor_ref": "#/font_floors",
        "connector_semantics_ref": "#/connector_semantics",
        "non_text_visual_requirement_ref": "#/non_text_visual_requirements",
        "prohibited": [
          "connector crossing readable text",
          "labels placed on rails",
          "route labels without explanatory audience text"
        ]
      },
      {
        "archetype_id": "executive_status_board",
        "use_when": "status proof, executive readout, or low-density route outcome summary",
        "layout_description": "Large status panels occupy the middle, supported by a separate proof or takeaway band and a visible hierarchy object.",
        "required_zones": [
          "title_zone",
          "claim_zone",
          "status_zone",
          "evidence_zone",
          "takeaway_zone"
        ],
        "content_schema": {
          "required_shape_roles": [
            "title",
            "core_sentence",
            "content_panel",
            "point_text",
            "evidence_item",
            "takeaway"
          ],
          "required_shape_role_groups": [
            "title_text",
            "core_claim_text",
            "content_container",
            "audience_body_text",
            "evidence_or_metric_text",
            "takeaway_text"
          ],
          "capacity_budget_ref": "#/capacity_budgets/archetype_budgets/executive_status_board"
        },
        "font_floor_ref": "#/font_floors",
        "connector_semantics_ref": "#/connector_semantics",
        "non_text_visual_requirement_ref": "#/non_text_visual_requirements",
        "prohibited": [
          "receipt label pile",
          "empty four-card grid",
          "tiny KPI badges"
        ]
      },
      {
        "archetype_id": "evidence_timeline",
        "use_when": "sequence, milestone, causal evolution, or proof chronology",
        "layout_description": "A timeline rail with milestone nodes and off-rail labels, with evidence and takeaway zones separated from the sequence.",
        "required_zones": [
          "title_zone",
          "claim_zone",
          "timeline_zone",
          "evidence_zone",
          "takeaway_zone"
        ],
        "content_schema": {
          "required_shape_roles": [
            "title",
            "core_sentence",
            "timeline_panel",
            "point_text",
            "evidence_item",
            "takeaway"
          ],
          "required_shape_role_groups": [
            "title_text",
            "core_claim_text",
            "timeline_marker",
            "audience_body_text",
            "evidence_or_metric_text"
          ],
          "capacity_budget_ref": "#/capacity_budgets/archetype_budgets/evidence_timeline"
        },
        "font_floor_ref": "#/font_floors",
        "connector_semantics_ref": "#/connector_semantics",
        "non_text_visual_requirement_ref": "#/non_text_visual_requirements",
        "prohibited": [
          "timeline rail through labels",
          "milestone text below floor",
          "more milestones than the selected zone capacity"
        ]
      },
      {
        "archetype_id": "risk_control_matrix",
        "use_when": "risks, controls, gates, criteria, or comparative quality readout",
        "layout_description": "A matrix or comparison field with filled cells, clear row and column grammar, and a separate signal or takeaway area.",
        "required_zones": [
          "title_zone",
          "claim_zone",
          "matrix_zone",
          "signal_zone",
          "takeaway_zone"
        ],
        "content_schema": {
          "required_shape_roles": [
            "title",
            "core_sentence",
            "compare_panel",
            "point_text",
            "metric",
            "takeaway"
          ],
          "required_shape_role_groups": [
            "title_text",
            "core_claim_text",
            "matrix_or_compare_container",
            "audience_body_text",
            "evidence_or_metric_text"
          ],
          "capacity_budget_ref": "#/capacity_budgets/archetype_budgets/risk_control_matrix"
        },
        "font_floor_ref": "#/font_floors",
        "connector_semantics_ref": "#/connector_semantics",
        "non_text_visual_requirement_ref": "#/non_text_visual_requirements",
        "prohibited": [
          "unfilled matrix cell",
          "four-card template for fewer than four facts",
          "flat equal panels without comparison semantics"
        ]
      },
      {
        "archetype_id": "decision_dashboard",
        "use_when": "decision, recommendation, operating readout, or proof dashboard",
        "layout_description": "A decision or recommendation zone creates first-glance hierarchy, with proof objects and takeaway separated by zones.",
        "required_zones": [
          "title_zone",
          "claim_zone",
          "decision_zone",
          "proof_zone",
          "takeaway_zone"
        ],
        "content_schema": {
          "required_shape_roles": [
            "title",
            "core_sentence",
            "content_panel",
            "point_text",
            "metric",
            "takeaway"
          ],
          "required_shape_role_groups": [
            "title_text",
            "core_claim_text",
            "content_container",
            "audience_body_text",
            "evidence_or_metric_text",
            "takeaway_text"
          ],
          "capacity_budget_ref": "#/capacity_budgets/archetype_budgets/decision_dashboard"
        },
        "font_floor_ref": "#/font_floors",
        "connector_semantics_ref": "#/connector_semantics",
        "non_text_visual_requirement_ref": "#/non_text_visual_requirements",
        "prohibited": [
          "all content in equal cards",
          "no first-glance hierarchy",
          "decision hidden below proof details"
        ]
      },
      {
        "archetype_id": "sample_status_proof_board",
        "use_when": "native_visual_sample true with one-slide route status proof",
        "layout_description": "One title, one claim, one wide input hub, three status cards, three vertical connector drops, and one proof band.",
        "required_zones": [
          "title_zone",
          "claim_zone",
          "status_zone",
          "proof_zone"
        ],
        "content_schema": {
          "required_shape_roles": [
            "title",
            "core_sentence",
            "input_hub",
            "content_panel",
            "point_text",
            "flow_connector",
            "proof_band"
          ],
          "required_shape_role_groups": [
            "title_text",
            "core_claim_text",
            "structural_input_hub",
            "status_card_triplet",
            "vertical_connector_triplet",
            "single_proof_sentence"
          ],
          "capacity_budget_ref": "#/capacity_budgets/sample_budgets/sample_status_proof_board"
        },
        "font_floor_ref": "#/font_floors",
        "connector_semantics_ref": "#/connector_semantics/sample_status_proof_board",
        "non_text_visual_requirement_ref": "#/non_text_visual_requirements/sample_status_proof_board",
        "prohibited": [
          "horizontal bus",
          "separate takeaway zone",
          "artifact inventory",
          "more or fewer than three status cards"
        ]
      },
      {
        "archetype_id": "sample_decision_proof_split",
        "use_when": "native_visual_sample true with one-slide decision and proof split",
        "layout_description": "One title, one claim, left decision panel, right proof stack, visible rail, and bottom takeaway band.",
        "required_zones": [
          "title_zone",
          "claim_zone",
          "decision_zone",
          "proof_zone",
          "takeaway_zone"
        ],
        "content_schema": {
          "required_shape_roles": [
            "title",
            "core_sentence",
            "content_panel",
            "decision_rail",
            "proof_rail",
            "takeaway"
          ],
          "required_shape_role_groups": [
            "title_text",
            "core_claim_text",
            "decision_panel",
            "proof_stack",
            "structural_rail",
            "takeaway_band"
          ],
          "capacity_budget_ref": "#/capacity_budgets/sample_budgets/sample_decision_proof_split"
        },
        "font_floor_ref": "#/font_floors",
        "connector_semantics_ref": "#/connector_semantics",
        "non_text_visual_requirement_ref": "#/non_text_visual_requirements/sample_decision_proof_split",
        "prohibited": [
          "status-board geometry",
          "three equal route cards",
          "missing decision or proof rail"
        ]
      }
    ]
  },
  "capacity_budgets": {
    "global": {
      "min_filled_required_zone_share": 0.8,
      "max_audience_text_shapes_per_slide": 14,
      "max_primary_points_per_slide": 5,
      "min_edge_margin_in": 0.6,
      "min_zone_gap_in": 0.32,
      "min_zone_inset_in": 0.15,
      "fit_strategy_order": [
        "select_lower_density_archetype",
        "reduce_slot_count",
        "shorten_copy",
        "resize_zones",
        "emit_coordinates"
      ],
      "font_shrink_to_fit_allowed": false
    },
    "archetype_budgets": {
      "professional_system_map": {
        "max_route_labels": 5,
        "max_gate_cards": 4,
        "max_evidence_items": 3
      },
      "executive_status_board": {
        "max_status_cards": 4,
        "min_card_width_in": 3.3,
        "min_card_height_in": 1.55
      },
      "evidence_timeline": {
        "max_milestone_count": 4,
        "max_evidence_items": 3
      },
      "risk_control_matrix": {
        "max_matrix_cells": 9,
        "empty_cell_allowed": false
      },
      "decision_dashboard": {
        "max_proof_objects": 4,
        "first_glance_hierarchy_required": true
      }
    },
    "samples": {
      "max_audience_text_shapes_per_slide": 12,
      "max_status_card_count": 3,
      "max_proof_text_count": 1,
      "artifact_inventory_visible_allowed": false
    },
    "sample_budgets": {
      "sample_status_proof_board": {
        "status_card_count": 3,
        "min_input_hub_width_in": 10.4,
        "min_input_hub_height_in": 0.82,
        "min_status_zone_height_in": 3.45,
        "min_proof_zone_height_in": 1.35,
        "connector_count": 3
      },
      "sample_decision_proof_split": {
        "max_decision_points": 2,
        "max_proof_items": 3,
        "min_takeaway_zone_height_in": 1.2
      }
    }
  },
  "font_floors": {
    "title_pt_min": 36,
    "sample_title_pt_min": 40,
    "body_pt_min": 18,
    "core_sentence_pt_min": 18,
    "point_index_pt_min": 16,
    "table_body_pt_min": 11,
    "input_hub_pt_min": 22,
    "title_to_body_ratio_min": 2,
    "font_floor_repair_policy": "change_geometry_copy_or_archetype_before_lowering_font"
