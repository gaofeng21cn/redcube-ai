          "visual_direction"
        ],
        "artifact_creation": [
          "author_image_pages",
          "render_html",
          "author_pptx_native"
        ],
        "review_and_revision": [
          "visual_director_review",
          "screenshot_review",
          "repair_image_pages",
          "fix_html",
          "repair_pptx_native"
        ],
        "package_and_handoff": [
          "export_pptx"
        ]
      },
      "xiaohongshu": {
        "source_intake": [
          "research"
        ],
        "communication_strategy": [
          "storyline",
          "single_note_plan"
        ],
        "visual_direction": [
          "visual_direction"
        ],
        "artifact_creation": [
          "author_image_pages",
          "render_html"
        ],
        "review_and_revision": [
          "visual_director_review",
          "screenshot_review",
          "repair_image_pages",
          "fix_html"
        ],
        "package_and_handoff": [
          "publish_copy",
          "export_bundle"
        ]
      },
      "poster_onepager": {
        "source_intake": [
          "storyline"
        ],
        "communication_strategy": [
          "poster_blueprint"
        ],
        "visual_direction": [
          "visual_direction"
        ],
        "artifact_creation": [
          "render_html"
        ],
        "review_and_revision": [
          "visual_director_review",
          "screenshot_review"
        ],
        "package_and_handoff": [
          "export_bundle"
        ]
