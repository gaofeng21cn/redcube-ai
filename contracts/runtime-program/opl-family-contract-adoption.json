{
  "contract_kind": "rca_opl_family_contract_adoption.v1",
  "domain_id": "redcube-ai",
  "domain_owner": "RedCube AI",
  "opl_role": "family-level projection consumer only",
  "attempt_projection": {
    "source_surfaces": [
      "product-entry session",
      "runtimeWatch",
      "artifact inventory",
      "runtime health"
    ],
    "maps_to_opl_contract": "opl_family_runtime_attempt_contract.v1",
    "owner_boundary": "RCA owns visual deliverable runtime and route truth"
  },
  "quality_projection": {
    "source_surfaces": [
      "content-fit review",
      "visual_director_review",
      "screenshot_review",
      "render proof",
      "export proof",
      "getReviewState",
      "getPublicationProjection"
    ],
    "maps_to_opl_contract": "opl_family_domain_quality_projection_contract.v1",
    "quality_gate_owner": "RCA visual deliverable quality",
    "claim_only_ready_forbidden": true
  },
  "incident_projection": {
    "source_surfaces": [
      "runtimeWatch",
      "managed deliverable report",
      "review/export gate audit",
      "operator handoff"
    ],
    "maps_to_opl_contract": "opl_family_incident_learning_loop.v1",
    "closure_rule": "domain-specific failure requires RCA-owned closure ref"
  },
  "operator_projection": {
    "source_surfaces": [
      "product entry",
      "product session",
      "internal OPL bridge",
      "artifact inventory",
      "review/publication projection refs"
    ],
    "maps_to_opl_contract": "opl_family_product_operator_projection.v1",
    "required_fields": [
      "source_refs",
      "freshness",
      "owner_split",
      "next_surface_ref",
      "human_gate_reason"
    ]
  },
  "lifecycle_adapter_surface": {
    "surface_kind": "opl_family_lifecycle_adapter",
    "adapter_id": "rca.opl.family.lifecycle.adapter.v1",
    "source_surfaces": [
      "managed-runs",
      "product-entry sessions",
      "review state",
      "publication projection",
      "artifact inventory",
      "runtime loop closure"
    ],
    "exposed_on": [
      "product-entry manifest",
      "direct product entry response",
      "product-entry session response",
      "federated product entry response"
    ],
    "maps_to_opl_contracts": [
      "opl_family_runtime_attempt_contract.v1",
      "opl_family_product_operator_projection.v1",
      "opl_family_domain_quality_projection_contract.v1"
    ],
    "adoption_state_values": [
      "discoverable_manifest_projection",
      "hydrated_session_projection"
    ],
    "sqlite_status": "deferred_for_rca",
    "authority_model": "file_authority_plus_rebuildable_artifact_indexes"
  },
  "stage_control_projection": {
    "surface_kind": "opl_family_stage_control_projection",
    "projection_id": "rca.opl.family.stage-control.projection.v1",
    "adapter_model": "descriptor_read_only",
    "maps_to_opl_contract": "opl_family_stage_control_plane.v1",
    "source_surfaces": [
      "hydrated overlay stage_sequence",
      "managed-runs",
      "runtimeWatch",
      "getReviewState",
      "getPublicationProjection",
      "artifact inventory"
    ],
    "covered_families": [
      "ppt_deck",
      "xiaohongshu",
      "poster_onepager"
    ],
    "family_stage_kinds": [
      "source_intake",
      "communication_strategy",
      "visual_direction",
      "artifact_creation",
      "review_and_revision",
      "package_and_handoff"
    ],
    "manifest_stage_descriptor_required_fields": [
