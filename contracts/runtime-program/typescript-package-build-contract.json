{
  "contract_id": "typescript-package-build-contract",
  "date_anchor": "2026-04-26",
  "owner": "redcube_ai",
  "language": "typescript",
  "scope": "Machine-readable package build and export transition contract for the RedCube AI TypeScript migration.",
  "current_transition_model": {
    "source_types_entry": "./src/index.ts",
    "runtime_export_kind": "compiled_dist_runtime_export",
    "compiled_runtime_target": "./dist/index.js",
    "compiled_types_target": "./dist/index.d.ts"
  },
  "transition_policy": {
    "new_packages_must_use_typescript_source": true,
    "new_runtime_js_exports_forbidden_without_contract": true,
    "source_js_exports_allowlisted_only": true,
    "package_build_migration_order": [
      "leaf utility packages",
      "contract/governance/overlay packages",
      "CLI/MCP entry packages",
      "runtime-family packages",
      "domain actions"
    ]
  },
  "quality_gates": {
    "typecheck": "npm run typecheck",
    "typecheck_model": "build_compiled_exports_then_no_emit",
    "build": "npm run build",
    "package_contract_test": "node --test tests/typescript-baseline.test.ts"
  },
  "legacy_source_js_runtime_exports": [],
  "compiled_dist_runtime_exports": [
