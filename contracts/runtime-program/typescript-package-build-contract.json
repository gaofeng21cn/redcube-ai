      "package_name": "@redcube/codex-cli-client",
      "exports": [
        {
          "subpath": ".",
          "target": "./dist/index.js"
        }
      ]
    },
    {
      "directory": "packages/redcube-config",
      "package_name": "@redcube/redcube-config",
      "exports": [
        {
          "subpath": ".",
          "condition": "default",
