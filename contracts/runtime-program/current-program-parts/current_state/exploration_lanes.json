        "render_html",
        "fix_html"
      ],
      "native_editable_pptx": [
        "author_pptx_native",
        "repair_pptx_native"
      ]
    },
    "deferred": [
      "full colorectal AI long PPT as routine regression fixture",
      "animation",
      "narration",
      "template import",
      "online image search",
      "SVG editor"
    ]
  },
