{
  "ppt_image_first_production_route": {
    "status": "landed",
    "contract": "contracts/runtime-program/ppt-image-first-production-route.json",
    "default_visual_route": "author_image_pages",
    "default_visual_policy": "image_first",
    "default_enabled": true,
    "production_route": true,
    "route_chain": [
      "storyline",
      "detailed_outline",
      "slide_blueprint",
      "visual_direction",
      "author_image_pages",
      "visual_director_review",
      "screenshot_review",
      "repair_image_pages",
      "export_pptx"
    ],
    "api_surface": {
      "endpoint": "codex_native_imagegen_skill",
      "tool": "image_generation",
      "model_selection": "inherited_from_codex_executor_native_imagegen",
      "explicit_provider_token_required": false,
      "token_persisted_in_artifacts": false
    },
    "style_system": {
      "default_profile": "prompts/ppt_deck/image-first-default-style-profile.json",
      "prompt_template": "prompts/ppt_deck/image_first_prompt_template.md",
      "user_style_reference_dir_takes_precedence": true
    },
    "fact_governance": {
      "fact_whitelist_surface": "shared_source_truth.readable_shared_source_truth_fields",
      "verification_ledger_surface": "reports/fact-verification-ledger.json",
      "forbidden_generated_artifacts": [
        "fake QR code",
        "fake download link",
        "fake DOI",
        "fake logo",
        "unverified hospital name",
        "unverified patient demographics",
        "unverified publication status",
        "page number",
        "slide number",
        "chapter corner label"
      ],
      "unresolved_claim_policy": "block_or_rephrase_as_general_without_unverified_specifics"
    },
    "verified_asset_overlay_policy": {
      "asset_overlay_surface": "verified_asset_overlay_manifest",
      "deterministic_overlay_only": true,
      "overlay_manifest_required": true,
      "composition_repair_allowed": false,
      "model_generation_forbidden": [
        "QR code",
        "download URL",
        "DOI",
        "logo",
        "publication screenshot"
      ]
    },
    "long_deck_production_contract": {
      "contract_id": "ppt_image_first_long_deck_production_v1",
      "source_reference_pattern": "full 65-page GPT-Image-2 colorectal AI lecture deck",
      "full_colorectal_ai_long_deck_regression_allowed_by_default": false,
      "canonical_slide_naming": "slideNN-short-name.png",
      "required_artifact_surfaces": [
        "prompts",
        "images_raw",
        "images_1920x1080",
        "style_refs",
        "fact_verification_ledger",
        "visual_qc_ledger",
        "contact_sheet",
        "pptx"
      ],
      "completeness_gates": [
        "expected slide count matches image page count",
        "continuous slideNN ordering",
        "all generated pages are 16:9 PNG",
        "exported PPTX has one full-slide image per slide",
        "exported PPTX media count matches slide count",
        "full-deck contact sheet or manifest exists for operator review"
      ],
      "line_divergence_policy": {
        "html_route_must_not_consume_image_route_pngs_by_default": true,
        "image_route_is_not_html_skin": true
      },
      "rejected_repair_route_policy": {
        "forbidden_for_page_fixes": [
          "PIL composition patch",
          "Canvas redraw patch",
          "HTML rebuild patch"
        ],
        "allowed_postprocess_scope": [
          "deterministic verified asset overlay only"
        ],
        "rejected_route_provenance_required": true
      }
    },
    "audience_language_policy": {
      "visible_operator_language_allowed": false,
      "forbidden_visible_fragments": [
        "汇报讨论用途",
        "客观专业版",
        "本次汇报边界",
        "不在展示页暴露",
        "本地原始文件名",
        "清洗脚本名",
        "RCA",
        "RedCube",
        "source intake",
        "author_pptx_native",
        "slide_blueprint",
        "visual_direction"
      ],
      "rewrite_target": "project-facing audience language"
    },
    "layout_legibility_policy": {
      "title_safe_zone_clear": {
        "required": true,
        "forbidden_elements": [
          "section chip",
          "corner card",
          "badge",
          "tag",
          "decorative label"
        ],
        "preferred_section_signal": "footer_or_omit"
      },
      "table_legibility": {
        "min_body_font_pt": 11,
        "max_blank_ratio_in_card": 0.38,
        "compact_cell_padding_required": true
      },
      "layout_density": {
        "avoid_oversized_empty_cards": true,
        "max_blank_ratio_in_card": 0.38
      }
    },
    "proof_runner": {
      "status": "landed",
      "command": "tools/image-ppt-proof/run.sh --output-dir artifacts/image-ppt-proof --mock-image-generation",
      "cli_command": "redcube image-ppt proof --output-dir artifacts/image-ppt-proof --mock-image-generation",
      "ci_contract": "tools/image-ppt-proof/ci-contract.json",
      "artifact_index": "artifacts/image-ppt-proof/artifact-index.json",
      "default_mode": "mock",
      "default_fixture": "tests/fixtures/ppt-image-first-lightweight/fixture.json",
      "max_default_slide_count": 6,
      "full_colorectal_ai_long_deck_regression_allowed_by_default": false,
      "live_mode_requires": [
        "codex_executor_native_imagegen_available"
      ]
    },
    "ci_optional_lane": {
      "status": "landed",
      "workflow": ".github/workflows/ci.yml",
      "triggers": [
        "workflow_dispatch",
        "nightly schedule 17 19 * * *",
        "pull_request label image-ppt-proof"
      ],
      "default_quality_lane_runs_real_image_generation": false,
      "uploads_artifact_index": true
    },
    "visual_qa_hardening": {
      "status": "landed",
      "default_live_api_required": false,
      "mechanical_checks": [
        "16:9",
        "non-empty PNG",
        "duplicate hash",
        "low information density",
        "edge crop risk",
        "title area crop risk",
        "fragmentation risk",
        "manifest presence",
        "internal field leak risk",
        "operator language leak",
        "title safe zone obstruction",
        "table font below 11pt",
        "sparse oversized card",
        "optional OCR manifest domain_action_adapter"
      ],
      "hard_block_checks": [
        "external_audience_language_ok",
        "title_safe_zone_clear",
        "table_legibility_ok",
        "layout_density_ok"
      ],
      "fail_closed_when_missing_png_or_manifest": true,
      "rerun_route": "repair_image_pages"
    },
    "cache_resume_and_repair": {
      "status": "landed",
      "cache_key_inputs": [
        "slide_blueprint_hash",
        "visual_direction_hash",
        "prompt_hash",
        "style_reference_hash",
        "model",
        "tool_options"
      ],
      "default_reuses_same_key_png": true,
      "repair_scope": "blocked_slide_ids_only",
      "unblocked_slide_policy": "reuse_prior_png_and_record_preserved_hashes",
      "fail_closed_when_prior_png_missing": true,
      "token_persistence_allowed": false
    },
    "operator_ux": {
      "status": "landed",
      "manifest_status_session_surfaces": [
        "image_first_proof_readiness",
        "style_reference_summary",
        "cache_status",
        "artifact_inventory",
        "blocked_reason"
      ],
      "controlled_helper_command": "redcube image-ppt proof",
      "public_skill_policy": "do_not_register_as_second_public_skill",
      "default_helper_mode": "mock",
      "live_helper_mode": "explicit"
    },
    "artifact_contract": {
      "pptx_editable_shapes": false,
      "source_visual_route_recorded": true,
      "required_artifacts": [
        "PNG image pages",
        "image manifest",
        "prompt manifest",
        "style manifest",
        "PPTX assembled from full-slide images",
        "PDF",
        "review capture",
        "export bundle",
        "artifact gallery",
        "final delivery manifest"
      ]
