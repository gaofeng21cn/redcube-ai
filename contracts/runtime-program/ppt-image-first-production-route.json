{
  "contract_id": "ppt_image_first_production_route_v1",
  "status": "landed",
  "deliverable_family": "ppt_deck",
  "default_visual_route": "author_image_pages",
  "default_visual_policy": "image_first",
  "default_enabled": true,
  "route_chain": [
    "storyline",
    "detailed_outline",
    "slide_blueprint",
    "visual_direction",
    "author_image_pages",
    "visual_director_review",
    "screenshot_review",
    "repair_image_pages",
    "export_pptx"
  ],
  "api_contract": {
    "endpoint": "/responses",
    "tool": "image_generation",
    "default_image_model": "gpt-image-2",
    "token_persistence_allowed": false,
    "artifact_provenance_fields": [
      "provider",
      "base_url_host",
      "endpoint",
      "request_model",
      "default_image_model",
      "tool_options",
      "response_id",
      "image_call_id",
      "revised_prompt",
      "image_sha256",
      "prompt_hash",
      "style_reference_hash",
      "cache_key",
      "cache_status",
      "source_image_hash",
      "generation_cost_proxy",
      "generated_at"
    ]
  },
  "style_contract": {
    "default_style_profile": "prompts/ppt_deck/image-first-default-style-profile.json",
    "prompt_template": "prompts/ppt_deck/image_first_prompt_template.md",
    "user_style_reference_dir_precedence": true,
    "style_reference_artifact_store_required": true
  },
  "fact_governance": {
    "fact_whitelist_surface": "shared_source_truth.readable_shared_source_truth_fields",
    "verification_ledger_surface": "reports/fact-verification-ledger.json",
    "rule": "visible factual claims in generated full-slide images must trace to whitelisted source truth, approved slide blueprint text, or operator-approved verified assets",
    "unresolved_claim_policy": "block_or_rephrase_as_general_without_unverified_specifics",
    "forbidden_generated_artifacts": [
      "fake QR code",
      "fake download link",
      "fake DOI",
      "fake logo",
      "unverified hospital name",
      "unverified patient demographics",
      "unverified publication status",
      "page number",
      "slide number",
      "chapter corner label"
    ]
  },
  "verified_asset_overlay_policy": {
    "asset_overlay_surface": "verified_asset_overlay_manifest",
    "allowed_overlay_assets": [
      "real QR code",
      "download entry",
      "verified UI screenshot",
      "verified paper screenshot",
      "operator supplied logo"
    ],
    "deterministic_overlay_only": true,
    "overlay_manifest_required": true,
    "machine_verification_required_when_applicable": true,
    "composition_repair_allowed": false,
    "model_generation_forbidden": [
      "QR code",
      "download URL",
      "DOI",
      "logo",
      "publication screenshot"
    ]
  },
  "long_deck_production_contract": {
    "contract_id": "ppt_image_first_long_deck_production_v1",
    "source_reference_pattern": "full 65-page GPT-Image-2 colorectal AI lecture deck",
    "applies_when": "expected_slide_count > proof_runner.max_default_slide_count or operator marks deck as long_deck",
    "full_colorectal_ai_long_deck_regression_allowed_by_default": false,
    "canonical_slide_naming": "slideNN-short-name.png",
    "expected_slide_count_source": "slide_blueprint.expected_slide_count || slide_blueprint.slides.length",
    "required_artifact_surfaces": [
      "prompts",
      "images_raw",
      "images_1920x1080",
      "style_refs",
      "fact_verification_ledger",
      "visual_qc_ledger",
      "contact_sheet",
      "pptx"
    ],
    "completeness_gates": [
      "expected slide count matches image page count",
      "continuous slideNN ordering",
      "all generated pages are 16:9 PNG",
      "exported PPTX has one full-slide image per slide",
      "exported PPTX media count matches slide count",
      "full-deck contact sheet or manifest exists for operator review"
    ],
    "line_divergence_policy": {
      "shared_truth_before_divergence": [
        "source_truth",
        "storyline"
      ],
      "divergence_allowed_from": [
        "detailed_outline",
        "slide_blueprint",
        "visual_direction"
      ],
      "html_route_must_not_consume_image_route_pngs_by_default": true,
      "image_route_is_not_html_skin": true
    },
    "rejected_repair_route_policy": {
      "forbidden_for_page_fixes": [
        "PIL composition patch",
        "Canvas redraw patch",
        "HTML rebuild patch"
      ],
      "allowed_postprocess_scope": [
        "deterministic verified asset overlay only"
      ],
      "rejected_route_provenance_required": true
    }
  },
  "review_export_gates": {
    "visual_director_review_consumes": [
      "full-slide PNG",
      "prompt manifest",
      "style manifest"
    ],
    "screenshot_review_consumes": [
      "full-slide PNG",
      "image_pages_bundle",
      "prompt manifest",
      "style manifest"
    ],
    "mechanical_checks": [
      "16:9",
      "non-empty PNG",
      "duplicate hash",
      "low information density",
      "edge crop risk",
      "title area crop risk",
      "fragmentation risk",
      "manifest presence",
      "internal field leak risk",
      "optional OCR manifest sidecar"
    ],
    "export_pptx": {
      "source_visual_route": "author_image_pages|repair_image_pages",
      "editable_shapes_claim_allowed": false,
      "full_slide_image_pages_allowed": true
    }
  },
  "alternate_routes": {
    "html": {
      "status": "production_selectable_optional",
      "explicit_selection_required": true,
      "routes": ["render_html", "fix_html"]
    },
    "native_editable_pptx": {
      "status": "production_selectable_optional",
      "explicit_selection_required": true,
      "routes": ["author_pptx_native", "repair_pptx_native"],
      "use_when": ["editable", "native PPTX", "DrawingML", "可编辑"]
    }
  },
  "proof_runner": {
    "command": "tools/image-ppt-proof/run.sh --output-dir artifacts/image-ppt-proof --mock-image-generation",
    "cli_command": "redcube image-ppt proof --output-dir artifacts/image-ppt-proof --mock-image-generation",
    "ci_contract": "tools/image-ppt-proof/ci-contract.json",
    "default_mode": "mock",
    "default_fixture": "tests/fixtures/ppt-image-first-lightweight/fixture.json",
    "max_default_slide_count": 6,
    "full_colorectal_ai_long_deck_regression_allowed_by_default": false,
    "live_mode": "explicit",
    "live_mode_requires": [
      "REDCUBE_CODEX_RESPONSES_IMAGE_GENERATION_CMD",
      "or OPENAI_API_KEY"
    ]
  },
  "runtime_hardening": {
    "artifact_cache": {
      "status": "landed",
      "key_inputs": [
        "slide_blueprint_hash",
        "visual_direction_hash",
        "prompt_hash",
        "style_reference_hash",
        "model",
        "tool_options"
      ],
      "reuse_policy": "reuse_same_key_png_and_provenance_unless_force_redraw_or_repair_target",
      "token_persistence_allowed": false
    },
    "repair_prompt_fidelity": {
      "status": "landed",
      "scope": "blocked_slide_ids_only",
      "preserve_unblocked_pages": true,
      "fail_closed_when_prior_png_missing": true
    },
    "operator_ux": {
      "status": "landed",
      "surfaces": [
        "manifest",
        "frontdesk",
        "session",
        "redcube image-ppt proof"
      ]
    }
  },
  "deferred": [
    "full colorectal AI long PPT as routine regression fixture",
    "animation",
    "narration",
    "template import",
    "online image search",
    "SVG editor"
  ]
}
